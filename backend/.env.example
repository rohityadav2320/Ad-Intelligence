# Copy this to .env and fill in your keys

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Anthropic / Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-key

# ElevenLabs Scribe — for video transcription (https://elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-key

# Video storage path (local dev only — on Railway set to /app/videos via volume)
VIDEO_STORAGE_PATH=../videos

# CORS allowed origins (comma separated, no spaces)
# Example: https://my-app.vercel.app,http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Meta Ad Library token (optional — leave blank to use Playwright scraper)
META_ACCESS_TOKEN=
